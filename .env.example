# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token_here

# Ollama fallback (used automatically when Anthropic rate limit is hit)
# Install Ollama from https://ollama.com, then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Xray (optional — only needed for export)
XRAY_CLIENT_ID=your_xray_client_id
XRAY_CLIENT_SECRET=your_xray_client_secret
